            ]
        },
        "weibel-devops": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@azure-devops/mcp",
                "WeibelRadars",
                "-p",
                "Weibel-BC-2023",
                "-d",
                "core",
