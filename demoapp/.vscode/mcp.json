{
    "servers": {
        "al-symbols-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "al-mcp-server",
                "--packages",
                "C:/Development/AL/Weibel/.alpackages"
            ]
        },
        "serena": {
            "command": "C:\\Users\\XKRPO\\.local\\bin\\uvx",
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "agent"
            ]
        },
        "bc-code-intel": {
            "command": "npx",
